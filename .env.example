# Application
APP_ENV=local
FRONTEND_PUBLIC_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3000
BACKEND_PORT=3000

# Database
DATABASE_URL=postgresql://cloudvault_user:change-me-password@localhost:5432/cloudvault_dev?schema=public

# Auth
JWT_SECRET=change-me-placeholder-not-a-real-secret
JWT_EXPIRES_IN=1h

# S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cloud-storage-local
S3_ACCESS_KEY_ID=change-me-access-key
S3_SECRET_ACCESS_KEY=change-me-placeholder-not-a-real-secret
S3_FORCE_PATH_STYLE=true

# Upload policy
MAX_UPLOAD_BYTES=104857600
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm
PRESIGNED_URL_TTL_SECONDS=300
